# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=emergency-response-secret-key-change-in-production
DATABASE_URL=sqlite:///emergency_response.db

# Africa's Talking Configuration
AT_USERNAME=sandbox
AT_API_KEY=your-africas-talking-api-key-here
USSD_SERVICE_CODE=*384#
USSD_CHANNEL=17925
SMS_SENDER_ID=EMERGENCY

# Security Configuration
ENCRYPTION_KEY=emergency-encryption-key-change-in-production
DATA_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=90

# Rate Limiting
USSD_RATE_LIMIT=3 per hour
SMS_RATE_LIMIT=5 per hour

# Payment Configuration (Optional)
PAYMENT_GATEWAY_URL=
PAYMENT_API_KEY=

# Logging
LOG_LEVEL=INFO